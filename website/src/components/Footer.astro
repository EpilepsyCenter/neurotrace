---
import Logo from './Logo.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = (p: string) => `${base}${p}`;
const repo = 'https://github.com/EpilepsyCenter/tracer';
---
<footer class="site-foot"><div class="wrap">
  <div class="foot">
    <div>
      <Logo size={20} showVersion={false} />
      <p class="desc">Patch-clamp &amp; field-recording analysis, locally on your machine.</p>
      <div style="margin-top:14px;"><span class="led ok">MIT licensed · open source</span></div>
    </div>
    <div>
      <h5>Product</h5>
      <ul>
        <li><a href={link('/features')}>Features</a></li>
        <li><a href={link('/workflow')}>Workflow</a></li>
        <li><a href={`${repo}/releases`}>Releases</a></li>
        <li><a href={`${repo}/blob/main/README.md`}>README</a></li>
      </ul>
    </div>
    <div>
      <h5>Reference</h5>
      <ul>
        <li><a href={link('/docs')}>User manual</a></li>
        <li><a href={`${repo}/blob/main/docs/MANUAL.md`}>MANUAL.md</a></li>
        <li><a href="https://github.com/NeuralEnsemble/python-neo">Neo formats</a></li>
        <li><a href={`${repo}/blob/main/AGENTS.md`}>Architecture</a></li>
      </ul>
    </div>
    <div>
      <h5>Project</h5>
      <ul>
        <li><a href={repo}>Source on GitHub</a></li>
        <li><a href={`${repo}/issues`}>Issues</a></li>
        <li><a href={`${repo}/blob/main/AGENTS.md`}>Contributing</a></li>
        <li><a href={`${repo}/blob/main/README.md#license`}>License (MIT)</a></li>
      </ul>
    </div>
  </div>
  <div class="foot-rule"></div>
  <div class="foot-bot">
    <span>© 2026 TRACER · v0.7.0</span>
    <span>Built for electrophysiologists, quietly.</span>
  </div>
</div></footer>
