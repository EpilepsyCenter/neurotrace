---
interface Props {
  size?: number;
  showVersion?: boolean;
  href?: string;
}
const base = import.meta.env.BASE_URL;
const { size = 28, showVersion = true, href = base } = Astro.props;
const lockup = `${base.replace(/\/$/, '')}/logo/TRACER-lockup-horizontal.png`;
---
<a class="brand" href={href}>
  <img class="lockup" src={lockup} alt="TRACER" style={`height:${size}px;width:auto;display:block;`} />
  {showVersion && <span class="version">v0.7.1</span>}
</a>
