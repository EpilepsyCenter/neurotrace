---
import Base from '../layouts/Base.astro';
import { marked } from 'marked';
import manualMd from '../../../docs/MANUAL.md?raw';

const repo = 'https://github.com/EpilepsyCenter/neurotrace';
const releases = `${repo}/releases`;
const manualUrl = `${repo}/blob/main/docs/MANUAL.md`;

const screenshotModules = import.meta.glob(
  '../../../docs/screenshots/*.{png,jpg,jpeg,svg,webp}',
  { eager: true, query: '?url', import: 'default' }
) as Record<string, string>;

const screenshotByName: Record<string, string> = {};
for (const [path, url] of Object.entries(screenshotModules)) {
  const name = path.split('/').pop();
  if (name) screenshotByName[name] = url;
}

const SCREENSHOT_RE = /!\[([^\]]*)\]\(screenshots\/([^)]+)\)/g;

function placeholderCard(name: string): string {
  return '<div class="manual-img-missing"><span class="k">Screenshot pending</span><span class="v">' + name + '</span></div>';
}

const mdWithScreenshots = manualMd.replace(SCREENSHOT_RE, (_m, alt, name) => {
  const url = screenshotByName[name];
  if (url) return '![' + alt + '](' + url + ')';
  return placeholderCard(name);
});

function slugify(s: string): string {
  return s.toLowerCase().replace(/[^\w\s-]/g, '').trim().replace(/\s+/g, '-');
}

interface Heading { level: number; text: string; id: string; }
function extractHeadings(md: string): Heading[] {
  const out: Heading[] = [];
  const seen = new Map<string, number>();
  const lines = md.split('\n');
  let inFence = false;
  for (const line of lines) {
    if (line.startsWith('```')) { inFence = !inFence; continue; }
    if (inFence) continue;
    const m = /^(#{1,3})\s+(.+?)\s*$/.exec(line);
    if (!m) continue;
    const level = m[1].length;
    const text = m[2].replace(/`/g, '');
    let id = slugify(text);
    const dup = seen.get(id) ?? 0;
    if (dup > 0) id = id + '-' + dup;
    seen.set(slugify(text), dup + 1);
    out.push({ level, text, id });
  }
  return out;
}

const headings = extractHeadings(mdWithScreenshots);
const chapters = headings.filter((h) => h.level === 2);

let html = await marked.parse(mdWithScreenshots, { gfm: true });

{
  const seen = new Map<string, number>();
  html = html.replace(
    /<h([1-3])>([\s\S]*?)<\/h\1>/g,
    (_m, levelStr, inner) => {
      const text = inner.replace(/<[^>]+>/g, '').trim();
      let id = slugify(text);
      const dup = seen.get(id) ?? 0;
      if (dup > 0) id = id + '-' + dup;
      seen.set(slugify(text), dup + 1);
      return '<h' + levelStr + ' id="' + id + '">' + inner + '</h' + levelStr + '>';
    }
  );
}
---
<Base title="NeuroTrace — Manual">
<style>
.doc-layout{display:grid;grid-template-columns:260px 1fr;gap:48px;padding:40px 0 80px;align-items:start;}

aside.side{position:sticky;top:72px;max-height:calc(100vh - 90px);overflow:auto;padding-right:8px;font-family:var(--font-mono);font-size:12px;}
aside.side h5{font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--text-muted);margin:0 0 14px;font-weight:500;display:flex;align-items:center;gap:8px;}
aside.side h5::before{content:'';width:5px;height:5px;background:var(--accent);}
aside.side h5.tail{margin-top:28px;}
aside.side ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:2px;}
aside.side a{display:block;padding:5px 10px;border-radius:var(--rad);color:var(--text-secondary);letter-spacing:0.02em;transition:all 0.1s;border-left:2px solid transparent;line-height:1.4;}
aside.side a:hover{background:var(--bg-secondary);color:var(--text-primary);}

main.doc{min-width:0;max-width:780px;}

.doc-header{padding-bottom:32px;margin-bottom:40px;border-bottom:1px solid var(--border);}
.doc-header .crumb{font-family:var(--font-mono);font-size:10px;color:var(--text-muted);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:14px;display:flex;gap:10px;align-items:center;}
.doc-header h1{font-family:var(--font-ui);font-weight:300;font-size:60px;line-height:1;letter-spacing:-0.02em;margin:0 0 18px;}
.doc-header h1 em{font-style:italic;color:var(--text-muted);}
.doc-header .lead{color:var(--text-secondary);font-size:17px;line-height:1.55;max-width:62ch;}
.doc-header .meta{margin-top:22px;display:flex;gap:10px;flex-wrap:wrap;}

.manual-body{font-family:var(--font-ui);font-size:15px;line-height:1.65;color:var(--text-primary);}
.manual-body > h1{display:none;}

.manual-body h2{
  font-family:var(--font-mono);font-size:17px;font-weight:600;
  text-transform:uppercase;letter-spacing:0.05em;color:var(--text-primary);
  margin:64px 0 14px;padding-bottom:8px;border-bottom:1px solid var(--border);
  scroll-margin-top:76px;
}
.manual-body h2::before{
  content:'';display:inline-block;width:8px;height:8px;background:var(--accent);
  margin-right:10px;vertical-align:middle;margin-top:-3px;
}
.manual-body h3{
  font-family:var(--font-mono);font-size:13px;font-weight:600;
  text-transform:uppercase;letter-spacing:0.04em;color:var(--text-primary);
  margin:36px 0 10px;scroll-margin-top:76px;
  display:flex;align-items:baseline;gap:10px;
}
.manual-body h3::before{
  content:'';width:5px;height:5px;background:var(--accent);
  display:inline-block;flex-shrink:0;
}

.manual-body p{margin:0 0 14px;color:var(--text-secondary);}
.manual-body strong{color:var(--text-primary);font-weight:600;}
.manual-body em{font-style:italic;}

.manual-body code{
  font-family:var(--font-mono);font-size:13px;
  background:var(--bg-secondary);padding:1px 6px;
  border:1px solid var(--border);border-radius:var(--rad);color:var(--text-primary);
}
.manual-body pre{
  background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--rad);
  padding:14px 16px;font-family:var(--font-mono);font-size:12.5px;line-height:1.55;
  overflow:auto;margin:0 0 18px;
}
.manual-body pre code{background:transparent;border:none;padding:0;font-size:12.5px;}

.manual-body a{color:var(--accent);}
.manual-body a:hover{text-decoration:underline;}

.manual-body ul,.manual-body ol{padding-left:24px;margin:0 0 16px;color:var(--text-secondary);}
.manual-body li{margin-bottom:5px;}
.manual-body ul li::marker{color:var(--accent);}

.manual-body table{width:100%;border-collapse:collapse;margin:0 0 18px;font-size:13px;}
.manual-body th,.manual-body td{
  text-align:left;padding:8px 12px;border-bottom:1px solid var(--border);
  vertical-align:top;
}
.manual-body th{
  font-family:var(--font-mono);font-size:10px;font-weight:600;
  letter-spacing:0.10em;text-transform:uppercase;color:var(--text-muted);
  background:var(--bg-secondary);
}
.manual-body td{color:var(--text-secondary);}
.manual-body td:first-child,.manual-body td:nth-child(2){color:var(--text-primary);}

.manual-body img{
  display:block;max-width:min(100%, 560px);height:auto;
  margin:18px auto;
  border:1px solid var(--border);border-radius:var(--rad);
  background:var(--bg-secondary);
}

.manual-body kbd{
  font-family:var(--font-mono);font-size:11px;
  background:var(--bg-surface);border:1px solid var(--border);border-bottom-width:2px;
  padding:1px 6px;border-radius:var(--rad);color:var(--text-primary);
}

.manual-body blockquote{
  border-left:2px solid var(--accent);
  padding:8px 16px;margin:0 0 16px;
  background:var(--bg-secondary);
  color:var(--text-secondary);
}

.manual-body hr{
  border:none;border-top:1px solid var(--border);margin:32px 0;
}

.manual-body .manual-img-missing{
  display:flex;flex-direction:column;gap:2px;
  padding:14px 18px;margin:18px auto;
  border:1px dashed var(--border);border-radius:var(--rad);
  background:var(--bg-secondary);
  font-family:var(--font-mono);font-size:11px;color:var(--text-muted);
  max-width:520px;
}
.manual-body .manual-img-missing .k{
  text-transform:uppercase;letter-spacing:0.1em;
  color:var(--text-secondary);font-weight:500;
}

@media (max-width:1100px){
  .doc-layout{grid-template-columns:220px 1fr;gap:32px;}
}
@media (max-width:900px){
  .doc-layout{grid-template-columns:1fr;}
  aside.side{position:static;max-height:none;}
}
</style>

<header class="page-hd"><div class="wrap">
  <div>
    <div class="eyebrow">Documentation · v0.6.1</div>
    <h1>The user<br><em>manual.</em></h1>
    <p class="sub">The full in-app manual, served from <a href={manualUrl}><code>docs/MANUAL.md</code></a> in the repository.</p>
  </div>
  <div class="meta">
    <span><strong>{chapters.length}</strong> chapters</span>
    <span><strong>v0.6.1</strong> current</span>
    <span class="led ok">Single page</span>
  </div>
</div></header>

<div class="wrap doc-layout">
  <aside class="side">
    <h5>Chapters</h5>
    <ul>
      {chapters.map((c) => (
        <li><a href={`#${c.id}`}>{c.text}</a></li>
      ))}
    </ul>
    <h5 class="tail">Source</h5>
    <ul>
      <li><a href={manualUrl}>docs/MANUAL.md</a></li>
      <li><a href={repo}>Repository</a></li>
      <li><a href={releases}>Releases</a></li>
    </ul>
  </aside>

  <main class="doc">
    <div class="doc-header">
      <div class="crumb"><span>Docs</span><span style="opacity:.4;">/</span><span>User manual</span></div>
      <h1>NeuroTrace <em>user manual.</em></h1>
      <p class="lead">Open a recording, navigate the group → series → sweep tree, and run the analysis modules over the trace. Below is the complete in-app reference — {chapters.length} chapters covering every analysis window, the persistence model, and the keyboard shortcuts.</p>
      <div class="meta">
        <span class="chip ok">v0.6.1</span>
        <span class="chip">macOS · Linux · Windows</span>
        <span class="chip">MIT</span>
      </div>
    </div>

    <article class="manual-body" set:html={html}></article>
  </main>
</div>
</Base>
